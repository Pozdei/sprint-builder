# .env для docker-compose. Этот файл — НЕ коммитить.
# Скопируй: cp .env.example .env, и заполни поля ниже.

# -------------------- БД --------------------
POSTGRES_USER=sprint_app
POSTGRES_PASSWORD=ПОМЕНЯЙ_МЕНЯ_длинный_случайный_пароль
POSTGRES_DB=sprint_builder

# -------------------- Jira --------------------
JIRA_BASE_URL=https://itlime.atlassian.net
JIRA_EMAIL=твой_email@lime-shop.com
JIRA_API_TOKEN=положи_свой_токен_сюда

# -------------------- Auth --------------------
# Сгенерируй случайный секрет:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=сгенерируй_длинный_секрет_не_оставляй_дефолт
JWT_EXPIRE_HOURS=24

# Первый администратор — создаётся при первом старте бэка.
ADMIN_EMAIL=admin@yourcompany.local
ADMIN_PASSWORD=надёжный_пароль

# -------------------- Caddy / домен --------------------
# Локально: оставь :80  (HTTP, без сертификата).
# На сервере: впиши свой домен, например sprint.yourcompany.com — Caddy сам
# выпустит Let's Encrypt сертификат. Email берётся из ADMIN_EMAIL.
DOMAIN=:80
