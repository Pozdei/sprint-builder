# Jira
JIRA_BASE_URL=https://itlime.atlassian.net
JIRA_EMAIL=pozdeev.sa@lime-shop.com
JIRA_API_TOKEN=положи_свой_токен_сюда

# БД
DATABASE_URL=postgresql+psycopg://sprint_app:sprint_local_dev@localhost:5432/sprint_builder

# Auth — сгенерируй случайную строку, например:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=сгенерируй_секрет_не_оставляй_дефолт
JWT_EXPIRE_HOURS=24

# Первый администратор — создаётся при первом старте бэкенда.
# После создания эти значения нужны только при дальнейших стартах
# (если их поменять — на работающего админа это не повлияет, нужны новые seed).
ADMIN_EMAIL=admin@yourcompany.local
ADMIN_PASSWORD=поменяй_меня_тоже

# Прокси (опционально)
# HTTP_PROXY=
# HTTPS_PROXY=
# REQUESTS_CA_BUNDLE=
# VERIFY_SSL=true
